@inherits LayoutComponentBase
@implements IDisposable
@using TaskTrackingSystem.Shared.Models.Menu
@using System.Security.Claims

<div class="flex h-screen bg-slate-50 font-sans text-slate-900 antialiased">
    <!-- Left Sidebar -->
    <aside class="flex w-64 flex-col border-r border-slate-200 bg-white">
        <!-- Brand / Header -->
        <div class="flex h-16 items-center px-6 border-b border-slate-100">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-slate-900 text-white font-bold">T</span>
            <span class="ml-3 font-semibold text-lg tracking-tight">TaskFlow</span>
        </div>

        <!-- Navigation Links -->
        <NavMenu />

        <!-- Profile Section -->
        <div class="border-t border-slate-100 p-4">
            <AuthorizeView>
                <Authorized>
                    <div class="flex items-center rounded-xl p-2 hover:bg-slate-50 transition-all">
                        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-900 text-white font-semibold text-sm shrink-0">
                            @(context.User.Identity?.Name?.Length > 0 ? context.User.Identity.Name[0].ToString().ToUpper() : "U")
                        </span>
                        <div class="ml-3 overflow-hidden flex flex-col">
                            <span class="text-sm font-semibold text-slate-900 truncate max-w-[130px]">@context.User.Identity?.Name</span>
                            <form method="post" action="/account/logout" class="mt-0.5">
                                <AntiforgeryToken />
                                <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-semibold text-left flex items-center gap-1 transition-all">
                                    <i data-lucide="log-out" class="h-3 w-3"></i>
                                    Sign Out
                                </button>
                            </form>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/login" class="flex items-center justify-center rounded-xl bg-slate-900 text-white px-4 py-2.5 text-sm font-medium hover:bg-slate-800 transition-all">
                        Sign In
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col overflow-y-auto">
        <header class="flex h-16 items-center justify-between border-b border-slate-200 bg-white px-8">
            <h1 class="text-lg font-semibold text-slate-900">Workspace</h1>
            <div class="flex items-center space-x-4">
                <button class="relative rounded-full p-1.5 text-slate-400 hover:bg-slate-50 hover:text-slate-500 transition-all">
                    <i data-lucide="bell" class="h-5 w-5"></i>
                    <span class="absolute right-1.5 top-1.5 h-2 w-2 rounded-full bg-rose-500"></span>
                </button>
            </div>
        </header>

        <div class="p-8">
            @if (isCheckingAuth)
            {
                <div class="flex items-center justify-center py-20">
                    <div class="flex items-center space-x-3 text-slate-500">
                        <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        <span class="text-sm font-medium">Checking authorization...</span>
                    </div>
                </div>
            }
            else if (isAuthorizedPage)
            {
                @Body
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-20 px-4">
                    <div class="rounded-full bg-rose-50 p-4 text-rose-600 mb-4">
                        <i data-lucide="shield-alert" class="h-12 w-12"></i>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900">Access Denied</h3>
                    <p class="text-slate-500 text-center mt-2 max-w-sm text-sm">
                        You do not have permission to access this page. Please contact your system administrator.
                    </p>
                    <a href="/dashboard" class="mt-6 inline-flex items-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 transition-colors shadow-sm">
                        <i data-lucide="arrow-left" class="h-4 w-4 mr-2"></i>
                        Back to Dashboard
                    </a>
                </div>
            }
        </div>
    </main>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private MenuAuthorizationService MenuAuthorization { get; set; } = default!;
    [Inject] private Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider { get; set; } = default!;

    private bool isAuthorizedPage;
    private bool isCheckingAuth = true;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        _ = CheckPageAuthorizationAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = CheckPageAuthorizationAsync();
    }

    private async Task CheckPageAuthorizationAsync()
    {
        isCheckingAuth = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);

            if (user.Identity?.IsAuthenticated != true)
            {
                if (MenuAuthorizationService.IsPublicRoute(relativePath))
                {
                    isAuthorizedPage = true;
                }
                else
                {
                    var returnPath = new Uri(Navigation.Uri).AbsolutePath;
                    Navigation.NavigateTo($"/login?ReturnUrl={Uri.EscapeDataString(returnPath)}", forceLoad: true);
                    return;
                }

                return;
            }

            if (MenuAuthorizationService.IsPublicRoute(relativePath))
            {
                isAuthorizedPage = true;
                return;
            }

            var allowedMenus = await MenuAuthorization.GetUserMenusAsync(user);
            isAuthorizedPage = MenuAuthorization.IsRouteAllowed(allowedMenus, relativePath);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking page auth: {ex.Message}");
            isAuthorizedPage = false;
        }
        finally
        {
            isCheckingAuth = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initIcons");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
