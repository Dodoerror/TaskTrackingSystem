@page "/register"
@layout Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Register — TaskFlow</PageTitle>

<div class="flex min-h-screen items-center justify-center bg-slate-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 bg-white p-8 rounded-2xl border border-slate-200 shadow-xl">
        <div>
            <div class="flex justify-center">
                <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-slate-900 text-white font-bold text-xl">T</span>
            </div>
            <h2 class="mt-6 text-center text-3xl font-extrabold text-slate-900">Create a new account</h2>
            <p class="mt-2 text-center text-sm text-slate-600">
                Or
                <a href="/login" class="font-medium text-slate-900 hover:underline">sign in to existing account</a>
            </p>
        </div>

        <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" class="mt-8 space-y-6">
            <DataAnnotationsValidator />
            
            <div class="space-y-4 rounded-md shadow-sm">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="firstName" class="block text-sm font-medium text-slate-700 mb-1">First Name</label>
                        <InputText id="firstName" @bind-Value="registerModel.FirstName" placeholder="First name" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                        <ValidationMessage For="@(() => registerModel.FirstName)" class="text-xs text-red-500 mt-1" />
                    </div>
                    <div>
                        <label for="lastName" class="block text-sm font-medium text-slate-700 mb-1">Last Name</label>
                        <InputText id="lastName" @bind-Value="registerModel.LastName" placeholder="Last name" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                        <ValidationMessage For="@(() => registerModel.LastName)" class="text-xs text-red-500 mt-1" />
                    </div>
                </div>
                <div>
                    <label for="username" class="block text-sm font-medium text-slate-700 mb-1">Username</label>
                    <InputText id="username" @bind-Value="registerModel.Username" placeholder="username" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                    <ValidationMessage For="@(() => registerModel.Username)" class="text-xs text-red-500 mt-1" />
                </div>
                <div>
                    <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <InputText id="email" type="email" @bind-Value="registerModel.Email" placeholder="user@example.com" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                    <ValidationMessage For="@(() => registerModel.Email)" class="text-xs text-red-500 mt-1" />
                </div>
                <div>
                    <label for="phone" class="block text-sm font-medium text-slate-700 mb-1">Phone (Optional)</label>
                    <InputText id="phone" @bind-Value="registerModel.Phone" placeholder="Phone number" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                    <ValidationMessage For="@(() => registerModel.Phone)" class="text-xs text-red-500 mt-1" />
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                    <InputText id="password" type="password" @bind-Value="registerModel.Password" placeholder="Min 6 characters" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                    <ValidationMessage For="@(() => registerModel.Password)" class="text-xs text-red-500 mt-1" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-3 rounded-lg bg-red-50 border border-red-100">
                    <p class="text-sm text-red-600 text-center">@errorMessage</p>
                </div>
            }

            <div>
                <button type="submit" disabled="@isSubmitting" class="group relative flex w-full justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 disabled:opacity-50 transition-colors shadow-sm">
                    @(isSubmitting ? "Registering..." : "Register")
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private RegisterDto registerModel = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleRegister()
    {
        isSubmitting = true;
        errorMessage = null;

        var client = HttpClientFactory.CreateClient("WebApi");
        try
        {
            var response = await client.PostAsJsonAsync("Auth/register", registerModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();
                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                    await customProvider.MarkUserAsAuthenticated(result.Token);
                    Navigation.NavigateTo("dashboard");
                }
                else
                {
                    errorMessage = "Failed to parse registration response.";
                }
            }
            else
            {
                var errorObj = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                errorMessage = errorObj != null && errorObj.TryGetValue("message", out var msg) 
                    ? msg 
                    : "Registration failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
