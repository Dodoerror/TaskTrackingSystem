@page "/login"
@layout Layout.EmptyLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@rendermode InteractiveServer
@using System.Text.Json
@using TaskTrackingSystem.Shared
@using TaskTrackingSystem.Shared.Models.Auth
@using TaskTrackingSystem.WebApp.Components.Partial
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Sign In — TaskFlow</PageTitle>

<div class="flex min-h-screen items-center justify-center bg-slate-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 bg-white p-8 rounded-2xl border border-slate-200 shadow-xl">
        <div>
            <div class="flex justify-center">
                <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-slate-900 text-white font-bold text-xl">T</span>
            </div>
            <h2 class="mt-6 text-center text-3xl font-extrabold text-slate-900">Sign in to your account</h2>
            <p class="mt-2 text-center text-sm text-slate-600">
                Or
                <a href="/register" class="font-medium text-slate-900 hover:underline">register a new account</a>
            </p>
        </div>

        <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" class="mt-8 space-y-6">
            <DataAnnotationsValidator />

            <div class="space-y-4 rounded-md shadow-sm">
                <div>
                    <label for="usernameOrEmail" class="block text-sm font-medium text-slate-700 mb-1">Username or Email</label>
                    <InputText id="usernameOrEmail" @bind-Value="loginModel.UsernameOrEmail" placeholder="Enter username or email" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                    <ValidationMessage For="@(() => loginModel.UsernameOrEmail)" class="text-xs text-red-500 mt-1" />
                </div>
                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Password</label>
                    <InputText id="password" type="password" @bind-Value="loginModel.Password" placeholder="••••••••" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                    <ValidationMessage For="@(() => loginModel.Password)" class="text-xs text-red-500 mt-1" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="p-3 rounded-lg bg-red-50 border border-red-100">
                    <p class="text-sm text-red-600 text-center">@errorMessage</p>
                </div>
            }

            <div>
                <button type="submit" disabled="@isSubmitting" class="group relative flex w-full justify-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 disabled:opacity-50 transition-colors shadow-sm">
                    @(isSubmitting ? "Signing in..." : "Sign In")
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    // Note: Ensure LoginDto is imported or reference its full namespace if it resides elsewhere
    private LoginDto loginModel = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = null;

        var client = HttpClientFactory.CreateClient("WebApi");
        try
        {
            var response = await client.PostAsJsonAsync("Auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                // Using the exact shared Result pattern class matching the Web API's envelope
                var result = await response.Content.ReadFromJsonAsync<Result<AuthResponseDto>>(Serialization.CaseInsensitive);

                if (result != null && result.IsSuccess && result.Value != null && !string.IsNullOrEmpty(result.Value.Token))
                {
                    var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                    await customProvider.MarkUserAsAuthenticated(result.Value.Token);

                    Navigation.NavigateTo("/dashboard");
                }
                else
                {
                    // Gracefully fallback to server-provided error messaging if available
                    errorMessage = result?.ErrorMessage ?? ResultMessages.ParseAuthResponseFailed;
                }
            }
            else
            {
                // Try reading structured failure data matching your custom Result pattern framework
                try
                {
                    var errorResult = await response.Content.ReadFromJsonAsync<Result<AuthResponseDto>>(Serialization.CaseInsensitive);
                    errorMessage = errorResult?.ErrorMessage ?? ResultMessages.InvalidCredentials;
                }
                catch
                {
                    errorMessage = ResultMessages.InvalidCredentials;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}