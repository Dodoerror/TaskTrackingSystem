@page "/projects/{ProjectId:long}/tasks"
@using Microsoft.AspNetCore.Authorization
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiClientService ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject MenuAuthorizationService MenuAuthorization

<PageTitle>Kanban Board</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
            <button @onclick="GoBack" class="rounded-lg p-2 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all">
                <i data-lucide="arrow-left" class="h-5 w-5"></i>
            </button>
            <div>
                <h2 class="text-3xl font-bold tracking-tight text-slate-900">Kanban Board</h2>
                <p class="text-slate-500 mt-1">Project #@ProjectId — Drag tasks between columns.</p>
            </div>
        </div>
        <button @onclick="OpenCreateTaskModal" class="inline-flex items-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 transition-colors shadow-sm">
            <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
            New Task
        </button>
    </div>

    @if (isLoading)
    {
        <div class="flex items-center justify-center py-20">
            <div class="flex items-center space-x-3 text-slate-500">
                <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                <span class="text-sm font-medium">Loading board...</span>
            </div>
        </div>
    }
    else
    {
        <!-- Kanban Columns -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            @foreach (var column in columns)
            {
                var tasksInColumn = tasks.Where(t => t.StatusId == column.StatusId).ToList();
                <div class="flex flex-col rounded-xl border border-slate-200 bg-slate-50/50 overflow-hidden min-h-[400px]">
                    <!-- Column Header -->
                    <div class="flex items-center justify-between px-4 py-3 bg-white border-b border-slate-100">
                        <div class="flex items-center space-x-2">
                            <span class="h-2.5 w-2.5 rounded-full @column.DotColor"></span>
                            <h3 class="text-sm font-semibold text-slate-900">@column.Name</h3>
                        </div>
                        <span class="flex h-6 w-6 items-center justify-center rounded-full bg-slate-100 text-xs font-semibold text-slate-600">@tasksInColumn.Count</span>
                    </div>

                    <!-- Cards -->
                    <div class="flex-1 p-3 space-y-3 overflow-y-auto">
                        @if (tasksInColumn.Any())
                        {
                            @foreach (var task in tasksInColumn)
                            {
                                <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm hover:shadow-md transition-shadow">
                                    <div class="flex items-start justify-between">
                                        <h4 class="text-sm font-semibold text-slate-900">@task.Title</h4>
                                        <span class="text-xs px-2 py-0.5 rounded-full font-medium @GetPriorityBadge(task.PriorityId)">@GetPriorityLabel(task.PriorityId)</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(task.Description))
                                    {
                                        <p class="text-xs text-slate-500 mt-1.5 line-clamp-2">@task.Description</p>
                                    }
                                    <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-50">
                                        <span class="text-xs text-slate-400">Due @task.DueDate.ToString("MMM dd")</span>
                                        <div class="flex items-center space-x-1">
                                            @if (column.StatusId > 1)
                                            {
                                                <button @onclick="() => MoveTask(task.Id, column.StatusId - 1)" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all" title="Move Left">
                                                    <i data-lucide="chevron-left" class="h-3.5 w-3.5"></i>
                                                </button>
                                            }
                                            @if (column.StatusId < 3)
                                            {
                                                <button @onclick="() => MoveTask(task.Id, column.StatusId + 1)" class="rounded p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all" title="Move Right">
                                                    <i data-lucide="chevron-right" class="h-3.5 w-3.5"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="flex items-center justify-center py-8">
                                <p class="text-xs text-slate-400">No tasks</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ===== Create Task Modal ===== *@
@if (showTaskModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-lg mx-4 overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
                <h3 class="text-lg font-semibold text-slate-900">New Task</h3>
                <button @onclick="CloseTaskModal" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all">
                    <i data-lucide="x" class="h-5 w-5"></i>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Title</label>
                    <input @bind="taskTitle" type="text" placeholder="Task title" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Description</label>
                    <textarea @bind="taskDescription" rows="3" placeholder="Task description" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Priority</label>
                        <select @bind="taskPriorityId" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all">
                            <option value="1">Low</option>
                            <option value="2">Medium</option>
                            <option value="3">High</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1.5">Due Date</label>
                        <input @bind="taskDueDate" type="date" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(taskError))
                {
                    <div class="p-3 rounded-lg bg-red-50 border border-red-100">
                        <p class="text-sm text-red-600">@taskError</p>
                    </div>
                }
            </div>
            <div class="flex items-center justify-end space-x-3 px-6 py-4 border-t border-slate-100 bg-slate-50/50">
                <button @onclick="CloseTaskModal" class="rounded-lg px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors">Cancel</button>
                <button @onclick="RequestCreateConfirmation" disabled="@isSaving" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 disabled:opacity-50 transition-colors">
                    @(isSaving ? "Creating..." : "Create Task")
                </button>
            </div>
        </div>
    </div>
}

@* ===== Confirm Dialog ===== *@
<ConfirmDialog IsVisible="showConfirmDialog"
               Title="@confirmTitle"
               Message="@confirmMessage"
               ConfirmText="@confirmButtonText"
               Icon="@confirmIcon"
               IconBgClass="@confirmIconBg"
               IconTextClass="@confirmIconText"
               ButtonClass="@confirmButtonClass"
               OnConfirm="HandleConfirmAction"
               OnCancel="CloseConfirmDialog" />

@code {
    [Parameter] public long ProjectId { get; set; }

    private bool isLoading = true;
    private bool showTaskModal = false;
    private bool isSaving = false;
    private string? taskError;

    // Confirm dialog state
    private bool showConfirmDialog = false;
    private string confirmTitle = "";
    private string confirmMessage = "";
    private string confirmButtonText = "";
    private string confirmIcon = "";
    private string confirmIconBg = "";
    private string confirmIconText = "";
    private string confirmButtonClass = "";
    private Func<Task>? confirmAction;
    private List<TaskDto> tasks = new();

    // Task form
    private string taskTitle = "";
    private string? taskDescription;
    private long taskPriorityId = 2;
    private DateTime taskDueDate = DateTime.Today.AddDays(7);

    private List<KanbanColumn> columns = new()
    {
        new(1, "To Do", "bg-slate-400"),
        new(2, "In Progress", "bg-blue-500"),
        new(3, "Done", "bg-emerald-500")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initIcons");
    }

    private async Task LoadTasks()
    {
        isLoading = true;
        var client = ApiClient.CreateClient();
        try
        {
            var result = await client.GetFromJsonAsync<Result<List<TaskDto>>>($"Project/{ProjectId}/tasks", Serialization.CaseInsensitive);
            if (result?.IsSuccess == true && result.Value != null)
                tasks = result.Value;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Load tasks error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task MoveTask(long taskId, long newStatusId)
    {
        var client = ApiClient.CreateClient();
        try
        {
            var response = await client.PatchAsync($"Task/{taskId}/status?statusId={newStatusId}", null);
            if (response.IsSuccessStatusCode)
            {
                var task = tasks.FirstOrDefault(t => t.Id == taskId);
                if (task != null) task.StatusId = newStatusId;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Move task error: {ex.Message}");
        }
    }

    private void GoBack() => Navigation.NavigateTo("/projects");

    private void OpenCreateTaskModal()
    {
        taskTitle = "";
        taskDescription = null;
        taskPriorityId = 2;
        taskDueDate = DateTime.Today.AddDays(7);
        taskError = null;
        showTaskModal = true;
    }

    private void CloseTaskModal()
    {
        showTaskModal = false;
        taskError = null;
    }

    private void RequestCreateConfirmation()
    {
        if (string.IsNullOrWhiteSpace(taskTitle))
        {
            taskError = "Task title is required.";
            return;
        }

        confirmTitle = "Create Task?";
        confirmMessage = "Are you sure you want to create this task?";
        confirmButtonText = "Create";
        confirmIcon = "plus-circle";
        confirmIconBg = "bg-emerald-50";
        confirmIconText = "text-emerald-500";
        confirmButtonClass = "bg-emerald-600 hover:bg-emerald-700";
        confirmAction = CreateTask;
        showConfirmDialog = true;
    }

    private async Task HandleConfirmAction()
    {
        showConfirmDialog = false;
        if (confirmAction != null)
            await confirmAction();
    }

    private void CloseConfirmDialog()
    {
        showConfirmDialog = false;
    }

    private async Task CreateTask()
    {
        if (string.IsNullOrWhiteSpace(taskTitle))
        {
            taskError = "Task title is required.";
            return;
        }

        isSaving = true;
        taskError = null;
        var client = ApiClient.CreateClient();

        try
        {
            var dto = new CreateTaskDto
            {
                Title = taskTitle,
                Description = taskDescription,
                ProjectId = ProjectId,
                StatusId = 1,
                PriorityId = taskPriorityId,
                DueDate = taskDueDate
            };
            var response = await client.PostAsJsonAsync("Task", dto);
            if (response.IsSuccessStatusCode)
            {
                CloseTaskModal();
                await LoadTasks();
            }
            else
            {
                taskError = "Failed to create task.";
            }
        }
        catch (Exception ex)
        {
            taskError = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetPriorityBadge(long priorityId) => priorityId switch
    {
        1 => "bg-slate-100 text-slate-600",
        2 => "bg-amber-100 text-amber-700",
        3 => "bg-red-100 text-red-700",
        _ => "bg-slate-100 text-slate-600"
    };

    private string GetPriorityLabel(long priorityId) => priorityId switch
    {
        1 => "Low",
        2 => "Medium",
        3 => "High",
        _ => "—"
    };

    private record KanbanColumn(long StatusId, string Name, string DotColor);
}
