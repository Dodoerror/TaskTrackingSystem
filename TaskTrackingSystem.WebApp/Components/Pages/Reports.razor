@page "/reports"
@using Microsoft.AspNetCore.Authorization
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject ApiClientService ApiClient
@inject IJSRuntime JS

<PageTitle>Reports</PageTitle>

<div class="space-y-8">
    <!-- Page Header -->
    <div>
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">Reports</h2>
        <p class="text-slate-500 mt-1">Analytics, task reports, and user productivity.</p>
    </div>

    <!-- Task Report Section -->
    <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h3 class="font-semibold text-lg text-slate-900">Task Report</h3>
        </div>

        <!-- Filters -->
        <div class="px-6 py-4 bg-slate-50/50 border-b border-slate-100">
            <div class="flex flex-wrap items-end gap-4">
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">Start Date</label>
                    <input @bind="filterStartDate" type="date" class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">End Date</label>
                    <input @bind="filterEndDate" type="date" class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">Status</label>
                    <select @bind="filterStatus" class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all">
                        <option value="">All</option>
                        <option value="1">To Do</option>
                        <option value="2">In Progress</option>
                        <option value="3">Done</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 mb-1">Project</label>
                    <select @bind="filterProjectId" class="rounded-lg border border-slate-200 px-3 py-1.5 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all">
                        <option value="0">All Projects</option>
                        @foreach (var p in projects)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <button @onclick="LoadTaskReport" class="inline-flex items-center rounded-lg bg-slate-900 px-4 py-1.5 text-sm font-medium text-white hover:bg-slate-800 transition-colors">
                    <i data-lucide="search" class="h-3.5 w-3.5 mr-1.5"></i>
                    Search
                </button>
            </div>
        </div>

        <!-- Task Report Table -->
        <div class="overflow-x-auto">
            @if (isLoadingTasks)
            {
                <div class="flex items-center justify-center py-12">
                    <svg class="animate-spin h-5 w-5 text-slate-400" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                </div>
            }
            else
            {
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-slate-100 bg-slate-50/60">
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Task</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Project</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Priority</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Assigned To</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Due Date</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @if (taskReports.Any())
                        {
                            @foreach (var t in taskReports)
                            {
                                <tr class="hover:bg-slate-50/50 transition-colors">
                                    <td class="px-6 py-3 text-sm font-medium text-slate-900">@t.Title</td>
                                    <td class="px-6 py-3 text-sm text-slate-500">@t.ProjectName</td>
                                    <td class="px-6 py-3">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @GetStatusBadge(t.StatusId)">@t.StatusName</span>
                                    </td>
                                    <td class="px-6 py-3">
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @GetPriorityBadge(t.PriorityId)">@t.PriorityName</span>
                                    </td>
                                    <td class="px-6 py-3 text-sm text-slate-500">@(t.AssignedToUser ?? "Unassigned")</td>
                                    <td class="px-6 py-3 text-sm text-slate-500">@t.DueDate.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-12 text-center">
                                    <i data-lucide="file-search" class="h-10 w-10 mx-auto text-slate-300 mb-3"></i>
                                    <p class="text-sm text-slate-400">No tasks found. Adjust filters and try again.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <!-- User Productivity Section -->
    <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100">
            <h3 class="font-semibold text-lg text-slate-900">User Productivity</h3>
        </div>

        @if (isLoadingProductivity)
        {
            <div class="flex items-center justify-center py-12">
                <svg class="animate-spin h-5 w-5 text-slate-400" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
            </div>
        }
        else
        {
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/60">
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">User</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Total Assigned</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Completed</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Efficiency</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (productivityList.Any())
                    {
                        @foreach (var u in productivityList)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-3">
                                        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 text-slate-700 font-semibold text-xs">
                                            @(u.FullName.Length > 0 ? u.FullName[0].ToString().ToUpper() : "U")
                                        </span>
                                        <div>
                                            <p class="text-sm font-semibold text-slate-900">@u.FullName</p>
                                            <p class="text-xs text-slate-400">@@@u.Username</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm font-medium text-slate-900">@u.TotalAssignedTasks</td>
                                <td class="px-6 py-4 text-sm font-medium text-emerald-600">@u.CompletedTasksCount</td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-3">
                                        <div class="flex-1 h-2 rounded-full bg-slate-100 overflow-hidden max-w-[120px]">
                                            <div class="h-full rounded-full bg-slate-900 transition-all" style="width: @(Math.Min(u.EfficiencyRatio, 100))%"></div>
                                        </div>
                                        <span class="text-sm font-medium text-slate-700">@u.EfficiencyRatio.ToString("F0")%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center">
                                <p class="text-sm text-slate-400">No productivity data available.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private bool isLoadingTasks = true;
    private bool isLoadingProductivity = true;
    private List<TaskReportDto> taskReports = new();
    private List<UserProductivityDto> productivityList = new();
    private List<ProjectDto> projects = new();

    // Filters
    private DateTime? filterStartDate;
    private DateTime? filterEndDate;
    private string? filterStatus;
    private int filterProjectId;

    protected override async Task OnInitializedAsync()
    {
        var client = ApiClient.CreateClient();
        try
        {
            projects = await client.GetFromJsonAsync<List<ProjectDto>>("Project", Serialization.CaseInsensitive) ?? new();
        }
        catch { }

        await System.Threading.Tasks.Task.WhenAll(LoadTaskReport(), LoadProductivity());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initIcons");
    }

    private async Task LoadTaskReport()
    {
        isLoadingTasks = true;
        StateHasChanged();

        var client = ApiClient.CreateClient();
        try
        {
            var query = "Report/tasks?";
            if (filterStartDate.HasValue) query += $"startDate={filterStartDate:yyyy-MM-dd}&";
            if (filterEndDate.HasValue) query += $"endDate={filterEndDate:yyyy-MM-dd}&";
            if (!string.IsNullOrEmpty(filterStatus)) query += $"status={filterStatus}&";
            if (filterProjectId > 0) query += $"projectId={filterProjectId}&";

            var result = await client.GetFromJsonAsync<Result<List<TaskReportDto>>>(query.TrimEnd('&', '?'), Serialization.CaseInsensitive);
            if (result?.IsSuccess == true && result.Value != null)
                taskReports = result.Value;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Task report error: {ex.Message}");
        }
        finally
        {
            isLoadingTasks = false;
            StateHasChanged();
        }
    }

    private async Task LoadProductivity()
    {
        isLoadingProductivity = true;
        var client = ApiClient.CreateClient();
        try
        {
            var result = await client.GetFromJsonAsync<Result<List<UserProductivityDto>>>("Report/user-productivity", Serialization.CaseInsensitive);
            if (result?.IsSuccess == true && result.Value != null)
                productivityList = result.Value;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Productivity error: {ex.Message}");
        }
        finally
        {
            isLoadingProductivity = false;
        }
    }

    private string GetStatusBadge(long statusId) => statusId switch
    {
        1 => "bg-slate-100 text-slate-700",
        2 => "bg-blue-100 text-blue-700",
        3 => "bg-emerald-100 text-emerald-700",
        _ => "bg-slate-100 text-slate-600"
    };

    private string GetPriorityBadge(long priorityId) => priorityId switch
    {
        1 => "bg-slate-100 text-slate-600",
        2 => "bg-amber-100 text-amber-700",
        3 => "bg-red-100 text-red-700",
        _ => "bg-slate-100 text-slate-600"
    };
}
