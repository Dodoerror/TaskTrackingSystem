@page "/roles"
@using Microsoft.AspNetCore.Authorization
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<PageTitle>Roles</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold tracking-tight text-slate-900">Roles</h2>
            <p class="text-slate-500 mt-1">Manage roles and assign permissions.</p>
        </div>
        <button @onclick="OpenCreateModal" class="inline-flex items-center rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-slate-800 transition-colors shadow-sm">
            <i data-lucide="plus" class="h-4 w-4 mr-2"></i>
            New Role
        </button>
    </div>

    @if (isLoading)
    {
        <LoadingSpinner Message="Loading roles..." />
    }
    else
    {
        <!-- Roles Table -->
        <div class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/60">
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Role</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Description</th>
                        <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (PagedRoles.Any())
                    {
                        @foreach (var role in PagedRoles)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-3">
                                        <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
                                            <i data-lucide="shield-check" class="h-4 w-4"></i>
                                        </span>
                                        <span class="text-sm font-semibold text-slate-900">@role.Name</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-500 max-w-xs truncate">@(role.Description ?? "—")</td>
                                <td class="px-6 py-4 text-sm text-slate-400">@role.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end space-x-2">
                                        <button @onclick="() => OpenPermissionsModal(role)" class="rounded-lg p-1.5 text-slate-400 hover:bg-indigo-50 hover:text-indigo-600 transition-all" title="Permissions">
                                            <i data-lucide="key-round" class="h-4 w-4"></i>
                                        </button>
                                        <button @onclick="() => OpenEditModal(role)" class="rounded-lg p-1.5 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all" title="Edit">
                                            <i data-lucide="pencil" class="h-4 w-4"></i>
                                        </button>
                                        <button @onclick="() => DeleteRole(role.Id)" class="rounded-lg p-1.5 text-slate-400 hover:bg-red-50 hover:text-red-500 transition-all" title="Delete">
                                            <i data-lucide="trash-2" class="h-4 w-4"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <EmptyState ColSpan="4" Icon="shield-check" Title="No roles yet" Subtitle="Create your first role to get started." />
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            <Pagination CurrentPage="currentPage"
                        TotalPages="TotalPages"
                        PageSize="pageSize"
                        TotalCount="roleList.Count"
                        OnPageChanged="HandlePageChanged"
                        OnPageSizeChanged="HandlePageSizeChanged" />
        </div>
    }
</div>

@* ===== Create / Edit Role Modal ===== *@
@if (showRoleModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
                <h3 class="text-lg font-semibold text-slate-900">@(isEditing ? "Edit Role" : "New Role")</h3>
                <button @onclick="CloseRoleModal" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all">
                    <i data-lucide="x" class="h-5 w-5"></i>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Name</label>
                    <input @bind="formName" type="text" placeholder="Role name" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1.5">Description</label>
                    <textarea @bind="formDescription" rows="3" placeholder="Description" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent transition-all"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(roleError))
                {
                    <div class="p-3 rounded-lg bg-red-50 border border-red-100">
                        <p class="text-sm text-red-600">@roleError</p>
                    </div>
                }
            </div>
            <div class="flex items-center justify-end space-x-3 px-6 py-4 border-t border-slate-100 bg-slate-50/50">
                <button @onclick="CloseRoleModal" class="rounded-lg px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors">Cancel</button>
                <button @onclick="SaveRole" disabled="@isSaving" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 disabled:opacity-50 transition-colors">
                    @(isSaving ? "Saving..." : (isEditing ? "Update" : "Create"))
                </button>
            </div>
        </div>
    </div>
}

@* ===== Assign Permissions Modal ===== *@
@if (showPermissionsModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 overflow-hidden">
            <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
                <h3 class="text-lg font-semibold text-slate-900">Permissions — @selectedRoleName</h3>
                <button @onclick="ClosePermissionsModal" class="rounded-lg p-1 text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-all">
                    <i data-lucide="x" class="h-5 w-5"></i>
                </button>
            </div>
            <div class="p-6 max-h-[400px] overflow-y-auto">
                @if (isLoadingPermissions)
                {
                    <div class="flex items-center justify-center py-8">
                        <svg class="animate-spin h-5 w-5 text-slate-400" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                    </div>
                }
                else
                {
                    @if (allPermissions.Any())
                    {
                        var grouped = allPermissions.GroupBy(p => p.Module);
                        @foreach (var group in grouped)
                        {
                            <div class="mb-4">
                                <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">@group.Key</h4>
                                <div class="space-y-2">
                                    @foreach (var perm in group)
                                    {
                                        var isChecked = selectedPermissionIds.Contains(perm.Id);
                                        <label class="flex items-center space-x-3 p-2 rounded-lg hover:bg-slate-50 cursor-pointer transition-colors">
                                            <input type="checkbox" checked="@isChecked" @onchange="(e) => TogglePermission(perm.Id, (bool)(e.Value ?? false))" class="h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-900" />
                                            <div>
                                                <p class="text-sm font-medium text-slate-700">@perm.Name</p>
                                                @if (!string.IsNullOrEmpty(perm.Description))
                                                {
                                                    <p class="text-xs text-slate-400">@perm.Description</p>
                                                }
                                            </div>
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-slate-400 text-center py-4">No permissions available.</p>
                    }
                }
            </div>
            <div class="flex items-center justify-end space-x-3 px-6 py-4 border-t border-slate-100 bg-slate-50/50">
                <button @onclick="ClosePermissionsModal" class="rounded-lg px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 transition-colors">Cancel</button>
                <button @onclick="SavePermissions" disabled="@isSavingPermissions" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 disabled:opacity-50 transition-colors">
                    @(isSavingPermissions ? "Saving..." : "Save Permissions")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool showRoleModal = false;
    private bool showPermissionsModal = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private bool isSavingPermissions = false;
    private bool isLoadingPermissions = false;
    private string? roleError;
    private List<RoleDto> roleList = new();

    // Pagination state
    private int currentPage = 1;
    private int pageSize = 10;

    private int TotalPages => (int)Math.Ceiling((double)roleList.Count / pageSize);

    private IEnumerable<RoleDto> PagedRoles =>
        roleList.Skip((currentPage - 1) * pageSize).Take(pageSize);

    // Role form
    private long editingId;
    private string formName = "";
    private string? formDescription;

    // Permissions modal
    private long selectedRoleId;
    private string selectedRoleName = "";
    private List<PermissionDto> allPermissions = new();
    private HashSet<long> selectedPermissionIds = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initIcons");
    }

    private async Task LoadRoles()
    {
        isLoading = true;
        var client = HttpClientFactory.CreateClient("WebApi");
        try
        {
            roleList = await client.GetFromJsonAsync<List<RoleDto>>("Role") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Load roles error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // Pagination handlers
    private void HandlePageChanged(int page)
    {
        currentPage = page;
    }

    private void HandlePageSizeChanged(int size)
    {
        pageSize = size;
        currentPage = 1;
    }

    // ===== Role CRUD =====
    private void OpenCreateModal()
    {
        isEditing = false;
        editingId = 0;
        formName = "";
        formDescription = null;
        roleError = null;
        showRoleModal = true;
    }

    private void OpenEditModal(RoleDto role)
    {
        isEditing = true;
        editingId = role.Id;
        formName = role.Name;
        formDescription = role.Description;
        roleError = null;
        showRoleModal = true;
    }

    private void CloseRoleModal()
    {
        showRoleModal = false;
        roleError = null;
    }

    private async Task SaveRole()
    {
        if (string.IsNullOrWhiteSpace(formName))
        {
            roleError = "Role name is required.";
            return;
        }

        isSaving = true;
        roleError = null;
        var client = HttpClientFactory.CreateClient("WebApi");

        try
        {
            if (isEditing)
            {
                var dto = new UpdateRoleDto { Name = formName, Description = formDescription };
                var response = await client.PutAsJsonAsync($"Role/{editingId}", dto);
                if (!response.IsSuccessStatusCode) { roleError = "Failed to update role."; return; }
            }
            else
            {
                var dto = new CreateRoleDto { Name = formName, Description = formDescription };
                var response = await client.PostAsJsonAsync("Role", dto);
                if (!response.IsSuccessStatusCode) { roleError = "Failed to create role."; return; }
            }
            CloseRoleModal();
            await LoadRoles();
        }
        catch (Exception ex) { roleError = ex.Message; }
        finally { isSaving = false; }
    }

    private async Task DeleteRole(long id)
    {
        var client = HttpClientFactory.CreateClient("WebApi");
        try
        {
            await client.DeleteAsync($"Role/{id}");
            await LoadRoles();
            if (currentPage > TotalPages && TotalPages > 0)
                currentPage = TotalPages;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Delete error: {ex.Message}");
        }
    }

    // ===== Permissions =====
    private async Task OpenPermissionsModal(RoleDto role)
    {
        selectedRoleId = role.Id;
        selectedRoleName = role.Name;
        isLoadingPermissions = true;
        showPermissionsModal = true;
        StateHasChanged();

        var client = HttpClientFactory.CreateClient("WebApi");
        try
        {
            allPermissions = await client.GetFromJsonAsync<List<PermissionDto>>("Permission") ?? new();

            var assignedResult = await client.GetFromJsonAsync<Result<List<long>>>($"Role/{role.Id}/permissions");
            selectedPermissionIds = new HashSet<long>(assignedResult?.Value ?? new());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Load permissions error: {ex.Message}");
        }
        finally
        {
            isLoadingPermissions = false;
            StateHasChanged();
        }
    }

    private void ClosePermissionsModal()
    {
        showPermissionsModal = false;
    }

    private void TogglePermission(long permId, bool isChecked)
    {
        if (isChecked)
            selectedPermissionIds.Add(permId);
        else
            selectedPermissionIds.Remove(permId);
    }

    private async Task SavePermissions()
    {
        isSavingPermissions = true;
        var client = HttpClientFactory.CreateClient("WebApi");
        try
        {
            var dto = new AssignPermissionsDto { PermissionIds = selectedPermissionIds.ToList() };
            var response = await client.PostAsJsonAsync($"Role/{selectedRoleId}/permissions", dto);
            if (response.IsSuccessStatusCode)
            {
                ClosePermissionsModal();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Save permissions error: {ex.Message}");
        }
        finally
        {
            isSavingPermissions = false;
        }
    }
}
