<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="TaskTrackingSystem.WebApp.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <!-- Tailwind Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        // A fun, vibrant color palette
                        background: "hsl(260 40% 98%)",       // Soft, playful lavender-white
                        foreground: "hsl(260 50% 15%)",       // Deep plum for readable text
                        card: "hsl(0 0% 100%)",               // Pure white cards to pop out
                        "card-foreground": "hsl(260 50% 15%)",
                        popover: "hsl(0 0% 100%)",
                        "popover-foreground": "hsl(260 50% 15%)",

                        primary: "hsl(262 80% 50%)",           // Vibrant electric purple
                        "primary-foreground": "hsl(0 0% 100%)",

                        secondary: "hsl(325 90% 60%)",         // Fun hot pink / magenta
                        "secondary-foreground": "hsl(0 0% 100%)",

                        muted: "hsl(260 30% 90%)",             // Soft pastel purple-gray
                        "muted-foreground": "hsl(260 20% 45%)",

                        accent: "hsl(170 80% 40%)",            // Fresh mint / teal for eye-catching bits
                        "accent-foreground": "hsl(0 0% 100%)",

                        border: "hsl(260 30% 88%)",           // Clean, visible borders
                    }
                }
            }
        }
    </script>
    <!-- Lucide Icons CDN -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        function initIcons() {
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }
        function downloadFile(filename, contentType, content) {
            const file = new Blob([content], {type: contentType});
            const exportUrl = URL.createObjectURL(file);
            const a = document.createElement("a");
            a.href = exportUrl;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(exportUrl);
        }
        // Run once loaded
        window.addEventListener('DOMContentLoaded', initIcons);
        // Blazor enhanced page updates trigger
        Blazor.addEventListener('enhancedload', initIcons);
    </script>
</body>

</html>