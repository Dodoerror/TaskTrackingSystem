<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="TaskTrackingSystem.WebApp.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        // Your custom palette mapped to semantic classes
                        background: "#E6E094",          // Pale olive / soft gold
                        foreground: "#2D2D2D",          // Dark charcoal for high contrast text
                        card: "#235A57",                // Deep teal for standard card elements
                        "card-foreground": "#E6E094",   // Soft gold text to pop on deep teal
                        popover: "#235A57",
                        "popover-foreground": "#E6E094",

                        primary: "#235A57",              // Deep teal
                        "primary-foreground": "#E6E094",

                        secondary: "#F9DCE1",            // Soft pink / rose accent
                        "secondary-foreground": "#2D2D2D",

                        muted: "#363636",                // Muted charcoal variant
                        "muted-foreground": "#E6E094",

                        accent: "#F9DCE1",               // Soft pink for eye-catching highlights
                        "accent-foreground": "#2D2D2D",

                        border: "#2D2D2D",               // Dark charcoal borders
                    }
                }
            }
        }
    </script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    <script>
        function initIcons() {
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }
        function downloadFile(filename, contentType, content) {
            const file = new Blob([content], {type: contentType});
            const exportUrl = URL.createObjectURL(file);
            const a = document.createElement("a");
            a.href = exportUrl;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(exportUrl);
        }
        // Run once loaded
        window.addEventListener('DOMContentLoaded', initIcons);
        // Blazor enhanced page updates trigger
        Blazor.addEventListener('enhancedload', initIcons);
    </script>
</body>

</html>